---
import LogoIcon from "@/assets/icons/ui/logo.svg";
import MenuIcon from "@/assets/icons/ui/menu.svg";
import CloseIcon from "@/assets/icons/ui/close.svg";
import ArrowRightIcon from "@/assets/icons/ui/arrow-right.svg";

interface NavigationItem {
  name: string;
  href: string;
}

type NavigationArray = Array<NavigationItem>;

const navigation: NavigationArray = [
  { name: "Home", href: "#hero" },
  { name: "Why Choose Us", href: "#why-choose-us" },
  { name: "Services", href: "#our-services" },
  { name: "Our Work", href: "#our-work" },
  { name: "Testimonials", href: "#testimonials" },
];
---

<header
  id="header"
  class="border-grey-50 sticky top-0 z-50 h-17 border-b bg-white px-5"
>
  <div
    id="header-bar"
    class="mx-auto flex h-full max-w-7xl items-center justify-between"
  >
    <a href="#hero" class="inline-flex items-center gap-2">
      <LogoIcon class="fill-primary-100 h-5" />
      <span class="font-semibold lg:text-lg">Lumos</span>
    </a>

    <nav class="hidden lg:block">
      <ul class="text-grey-200 flex items-center gap-8">
        {
          navigation.map(({ name, href }) => (
            <li>
              <a
                href={href}
                class="text-sm font-medium transition-colors duration-300 hover:text-black lg:text-base"
              >
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href="#contact-us"
      class="bg-primary-100 hover:bg-primary-200 hidden h-9 items-center gap-1 rounded-3xl px-3 transition-colors duration-300 lg:flex"
    >
      <span class="text-sm font-medium text-white lg:text-base">Contact Us</span
      >
      <ArrowRightIcon class="size-5 stroke-white" />
    </a>

    <button
      id="open-menu"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="flex items-center lg:hidden"
    >
      <MenuIcon aria-hidden="true" class="size-6 stroke-black" />
    </button>
  </div>

  <!-- Mobile menu -->
  <dialog
    id="mobile-menu"
    aria-label="Navigation menu"
    class="open:animate-menu-in [.is-closing]:animate-menu-out fixed inset-x-0 top-0 m-0 min-h-dvh w-full max-w-none flex-col bg-white p-0 transition-opacity duration-300 backdrop:hidden open:flex lg:hidden"
  >
    <div
      class="border-grey-50 flex h-17 shrink-0 items-center justify-between border-b px-5"
    >
      <a href="#hero" class="inline-flex items-center gap-2">
        <LogoIcon class="fill-primary-100 h-5" />
        <span class="font-semibold">Lumos</span>
      </a>
      <button id="close-menu" aria-label="Close menu" class="flex items-center">
        <CloseIcon aria-hidden="true" class="size-6 stroke-black" />
      </button>
    </div>

    <nav class="flex flex-1 flex-col justify-center px-5">
      <ul class="flex flex-col gap-2 text-center">
        {
          navigation.map(({ name, href }) => (
            <li>
              <a href={href} class="block py-3 text-lg font-medium">
                {name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex shrink-0 justify-center px-5 pb-8">
      <a
        href="#contact-us"
        class="bg-primary-100 active:bg-primary-200 hover:bg-primary-200 flex h-12 items-center justify-center gap-1 rounded-3xl px-4 transition-colors duration-300"
      >
        <span class="font-medium text-white">Contact Us</span>
        <ArrowRightIcon class="size-5 stroke-white" />
      </a>
    </div>
  </dialog>
</header>

<script>
  const openBtn = document.getElementById("open-menu") as HTMLButtonElement;
  const closeBtn = document.getElementById("close-menu") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLDialogElement;

  function openMenu() {
    const scrollbarWidth =
      window.innerWidth - document.documentElement.clientWidth;
    document.documentElement.style.paddingRight = `${scrollbarWidth}px`;
    document.documentElement.classList.add("overflow-hidden");
    menu.showModal();
    openBtn.setAttribute("aria-expanded", "true");
    closeBtn.focus({ preventScroll: true });
  }

  function closeMenu() {
    menu.classList.add("is-closing");
  }

  menu.addEventListener("animationend", (e) => {
    if ((e.target as HTMLElement).closest("dialog") !== menu) return;
    if (!menu.classList.contains("is-closing")) return;
    menu.classList.remove("is-closing");
    menu.close();
    openBtn.setAttribute("aria-expanded", "false");
    document.documentElement.classList.remove("overflow-hidden");
    document.documentElement.style.paddingRight = "";
    openBtn.focus({ preventScroll: true });
  });

  // Intercept native Escape to use animated close
  menu.addEventListener("cancel", (e) => {
    e.preventDefault();
    closeMenu();
  });

  openBtn.addEventListener("click", openMenu);
  closeBtn.addEventListener("click", closeMenu);

  // Close on nav link click
  menu.querySelectorAll("a[href]").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Active section highlighting
  const headerEl = document.getElementById("header") as HTMLElement;
  const desktopNavLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(
      "#header-bar nav a[href^='#']",
    ),
  );

  const sectionMap = desktopNavLinks
    .map((link) => ({
      link,
      el: document.getElementById(link.getAttribute("href")!.slice(1)),
    }))
    .filter(
      (item): item is { link: HTMLAnchorElement; el: HTMLElement } =>
        item.el !== null,
    );

  function updateActiveLink() {
    const headerH = headerEl.offsetHeight;
    let activeLink: HTMLAnchorElement | null = null;

    for (const { link, el } of sectionMap) {
      if (el.getBoundingClientRect().top <= headerH + 1) {
        activeLink = link;
      }
    }

    for (const { link } of sectionMap) {
      link.classList.toggle("text-black", link === activeLink);
    }
  }

  window.addEventListener("scroll", updateActiveLink, { passive: true });
  updateActiveLink();
</script>
