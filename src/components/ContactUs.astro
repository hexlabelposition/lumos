---
import LogoIcon from "@/assets/icons/ui/logo.svg";
import ArrowRightIcon from "@/assets/icons/ui/arrow-right.svg";
---

<section id="contact-us" class="px-5 py-6 lg:py-14">
  <div class="mx-auto max-w-7xl">
    <div
      class="relative flex flex-col gap-8 overflow-hidden rounded-3xl bg-black p-8 text-white lg:p-14"
    >
      <header class="flex flex-col gap-4 lg:gap-6">
        <div class="flex flex-col gap-2">
          <span class="text-grey-100 text-xs uppercase lg:text-base"
            >Contact Us</span
          >
          <h2
            class="text-2xl leading-tight font-medium tracking-tight lg:text-5xl"
          >
            Let's bring your vision to life
          </h2>
        </div>
        <p class="text-grey-100 max-w-2xl text-sm lg:text-base">
          Have a project in mind? Let's collaborate and create something
          extraordinary. Reach out to us, and we'll help turn your ideas into
          impactful digital experiences.
        </p>
      </header>

      <a
        href="mailto:hello@lumoscreative.com"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary-100 hover:bg-primary-200 active:bg-primary-200 flex min-h-12 items-center gap-2 self-start rounded-3xl px-4 transition-colors duration-300 lg:px-5"
      >
        <span class="text-sm font-medium lg:text-base">Get in touch</span>
        <ArrowRightIcon class="size-5 stroke-white lg:size-6" />
      </a>

      <LogoIcon
        class="pointer-events-none absolute right-1/2 bottom-0 h-60 w-104 translate-x-1/2 translate-y-1/4 transform fill-white opacity-5 sm:right-0 sm:translate-x-1/4 lg:h-75 lg:w-130"
      />
    </div>
  </div>
</section>
